---
import Base from "../layouts/Base.astro";
---
<Base bg>
  <section class="hero measure">
    <p class="kicker"><span class="ink">Content Designer</span> → Content Strategist</p>
    <h1>
      I make products talk the way <span class="red">people</span> do.
    </h1>
    <p class="subtitle">I'm a writer, artist, and lover of languages, trained in communications, digital media, and engineering. On a journey to expand content design from words to <span class="nowrap">AI-forward</span> systems.</p>
    <p class="muted lede">
      I build the connective tissue for products to be cohesive in large ecosystems, including <span class="red">terminology research</span>, <span class="red">object guides</span> and mapping the relationships between concepts, alongside style and <span class="red">Responsible AI guidelines</span> to create comprehensive content systems.<span class="cursor" aria-hidden="true"></span>
    </p>
  </section>

  <section class="paths">
    <a class="path" href="/story">
      <span class="path-title">My st<span class="green">o</span>ry</span>
      <span class="path-sub">The stories that shape me and how I make sense of the world.</span>
    </a>
    <a class="path" href="/work">
      <span class="path-title">The w<span class="green">o</span>rk</span>
      <span class="path-sub">Where work leads to passion and inspiration finds me.</span>
    </a>
  </section>

  <p class="skills-note">
    <svg class="fly" viewBox="0 0 24 24" aria-hidden="true"><ellipse cx="12" cy="15" rx="3.2" ry="4.2"/><path d="M12 12C10 8 7 6 4 7" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 12C14 8 17 6 20 7" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>A person is a tree, and <a href="/skills">skills</a> fireflies.
  </p>

  <style>
    /* Two type sizes only: a headline size and a body size.
       Hierarchy comes from weight and colour, not more sizes. */
    .hero.measure { max-width: 82ch; }
    .hero { margin-bottom: 4.5rem; }
    .hero h1 { font-size: clamp(1.9rem, 4.5vw, 3rem); margin: 0.5rem 0 1.25rem; line-height: 1.15; }
    .subtitle {
      font-size: 1.05rem; font-weight: 400;
      color: var(--ink); margin: 0 0 1.25rem; line-height: 1.5;
    }
    .subtitle .nowrap { white-space: nowrap; }
    .lede { font-size: 1.05rem; }

    .paths { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--ink); border: 2px solid var(--ink); }
    .path {
      background: var(--paper); padding: 1.75rem 1.5rem; border: 0;
      display: flex; flex-direction: column; gap: 0.4rem; min-height: 130px;
    }
    .path:hover { background: var(--ink); color: var(--paper); }
    .path:hover .path-sub { color: var(--paper); }
    .path-title { font-size: 1.05rem; font-weight: 700; }
    .path-sub { color: var(--grey-600); font-size: 1.05rem; margin-top: auto; }

    @media (max-width: 640px) { .paths { grid-template-columns: 1fr; } }

    .skills-note {
      margin-top: 1.5rem; text-align: left;
      color: var(--ink);
      font-size: 1.05rem;
    }
    .skills-note .fly {
      width: 1.05em; height: 1.05em; display: inline-block;
      color: var(--ink); fill: var(--ink);
      margin-right: 0.4em; vertical-align: -0.18em;
    }
    .skills-note a { color: var(--green); text-decoration: underline; border: 0; }
    .skills-note a:hover { color: var(--red); }
  </style>
</Base>
