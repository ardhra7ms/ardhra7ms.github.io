---
import Base from "../layouts/Base.astro";
---
<Base bg>
  <section class="hero measure">
    <p class="kicker">Content Designer → <span class="green">Content Strategist</span></p>
    <h1>
      I design how products <span class="red">talk</span> —
      the user's moment and the product's intent, at the same time.
    </h1>
    <p class="muted lede">
      Writer–designer–engineer. I build the connective tissue of an experience —
      terminology, guidance, the relationships between concepts — so meaning holds
      across a whole product. Increasingly, that means designing how AI talks.<span class="cursor" aria-hidden="true"></span>
    </p>
  </section>

  <section class="paths">
    <a class="path" href="/story">
      <span class="path-title">My st<span class="green">o</span>ry</span>
      <span class="path-sub">A magazine, not a résumé. Get to know me — in my own words.</span>
    </a>
    <a class="path" href="/work">
      <span class="path-title">The w<span class="green">o</span>rk</span>
      <span class="path-sub">Where work takes me. Where work meets passion. When inspiration finds me in daydreams (at night).</span>
    </a>
  </section>

  <p class="skills-note">
    <svg class="fly" viewBox="0 0 24 24" aria-hidden="true"><ellipse cx="12" cy="15" rx="3.2" ry="4.2"/><path d="M12 12C10 8 7 6 4 7" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 12C14 8 17 6 20 7" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>A person is a tree, and <a href="/skills">skills</a> fireflies.
  </p>

  <style>
    .hero { margin-bottom: 4.5rem; }
    .hero h1 { font-size: clamp(1.8rem, 4.5vw, 3rem); margin: 0.5rem 0 1.5rem; }
    .lede { font-size: 1.05rem; }

    .paths { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--ink); border: 2px solid var(--ink); }
    .path {
      background: var(--paper); padding: 1.75rem 1.5rem; border: 0;
      display: flex; flex-direction: column; gap: 0.4rem; min-height: 150px;
    }
    .path:hover { background: var(--ink); color: var(--paper); }
    .path:hover .path-sub { color: var(--paper); }
    .path-title { font-size: 1.4rem; font-weight: 700; }
    .path-sub { color: var(--grey-600); font-size: 0.9rem; margin-top: auto; }

    @media (max-width: 640px) { .paths { grid-template-columns: 1fr; } }

    .skills-note {
      margin-top: 1.5rem; text-align: left;
      color: var(--green); font-weight: 600;
      font-size: 0.95rem;
    }
    .skills-note .fly {
      width: 1.05em; height: 1.05em; display: inline-block;
      color: var(--ink); fill: var(--ink);
      margin-right: 0.4em; vertical-align: -0.18em;
    }
    .skills-note a { color: var(--green); text-decoration: underline; border: 0; }
    .skills-note a:hover { color: var(--red); }
  </style>
</Base>
