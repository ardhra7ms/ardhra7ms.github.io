---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

const entries = (await getCollection("story"))
  .filter((e) => !e.data.draft && !e.id.startsWith("_"))
  .sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  entries.map(async (e) => ({ data: e.data, Content: (await render(e)).Content }))
);

// Page 0 is the cover; each story piece is a page after it.
const total = rendered.length + 1;
---
<Base bg title="My story — Ardhra Sivasankaran">
  {rendered.length === 0 ? (
    <section class="measure"><p class="muted"><em>The first pages are being written.</em></p></section>
  ) : (
    <div class="mag" data-total={total}>
      <div class="mag-stage">
        <!-- Cover -->
        <article class="page is-active" data-page="0">
          <div class="page-inner cover">
            <p class="kicker">B-side</p>
            <figure class="cover-photo">
              <img src="/files/photos/ardhra.jpg" alt="Ardhra" loading="eager"
                   onerror="this.style.display='none'; this.parentElement.classList.add('is-empty');" />
              <figcaption class="photo-ph" aria-hidden="true">your photo</figcaption>
            </figure>
            <div class="cover-text">
              <h1>Between<br/>the lines.<span class="cursor" aria-hidden="true"></span></h1>
              <p class="muted cover-line">
                There's more to me than I can fit into a page or project, so here's
                more about me if you'd like to know. :)
              </p>
            </div>
            <p class="cover-hint">Click the page, or use ← →</p>
          </div>
        </article>

        {rendered.map((e, i) => (
          <article class="page" data-page={i + 1}>
            <div class="page-inner">
              <span class="piece-no">{String(i + 1).padStart(2, "0")}</span>
              <h2>{e.data.title}</h2>
              <div class="prose"><e.Content /></div>
            </div>
          </article>
        ))}
      </div>

      <nav class="mag-controls" aria-label="Magazine pages">
        <button class="turn prev" type="button" aria-label="Previous page" disabled>←</button>
        <span class="folio" aria-live="polite"><span class="cur">1</span> / {total}</span>
        <button class="turn next" type="button" aria-label="Next page">→</button>
      </nav>
    </div>
  )}

  <style>
    .mag { max-width: 760px; margin: 0 auto; }

    .mag-stage {
      position: relative;
      min-height: clamp(340px, 42vh, 520px);
      perspective: 2000px;
      overflow: hidden;
    }

    .page {
      position: absolute;
      inset: 0;
      opacity: 0;
      pointer-events: none;
      transform-origin: left center;
      transform: rotateY(-12deg);
      transition: opacity .35s ease, transform .45s ease;
    }
    .page.is-active {
      position: relative;
      opacity: 1;
      pointer-events: auto;
      transform: rotateY(0deg);
    }
    .page.turn-out-left { transform: rotateY(35deg); opacity: 0; }
    .page.turn-out-right { transform: rotateY(-35deg); opacity: 0; }

    .page-inner {
      background: #fff;
      border: 1px solid var(--grey-200);
      border-left: 3px solid var(--red);
      padding: clamp(1.5rem, 4vw, 3rem);
      box-shadow: 0 1px 0 var(--grey-100), 8px 8px 0 var(--grey-100);
      min-height: clamp(340px, 42vh, 520px);
      cursor: pointer;
    }

    .cover { display: grid; grid-template-columns: auto 1fr; align-items: center; gap: clamp(1.5rem, 4vw, 3rem); min-height: auto; }
    .cover .kicker { grid-column: 1 / -1; margin: 0; }
    .cover h1 { font-size: clamp(2rem, 5.5vw, 3.4rem); margin: 0 0 1.2rem; }
    .cover-text { display: flex; flex-direction: column; }
    .cover-line { max-width: 52ch; margin: 0; }
    .cover-hint { grid-column: 1 / -1; margin: 1.5rem 0 0; color: var(--grey-400); font-size: 0.85rem; }
    .cover-photo {
      margin: 0; width: clamp(160px, 22vw, 240px);
      aspect-ratio: 4 / 5; overflow: hidden; align-self: center;
      border: 1px solid var(--grey-200); border-left: 3px solid var(--red);
    }
    .cover-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .cover-photo .photo-ph { display: none; }
    .cover-photo.is-empty {
      display: flex; align-items: center; justify-content: center;
      background: var(--grey-100);
    }
    .cover-photo.is-empty .photo-ph {
      display: block; color: var(--grey-400); font-size: 0.75rem;
      text-transform: uppercase; letter-spacing: 0.12em;
    }
    @media (max-width: 600px) {
      .cover { grid-template-columns: 1fr; }
      .cover-photo { justify-self: start; }
    }
      margin-top: 2.5rem; font-size: 0.8rem; letter-spacing: 0.08em;
      color: var(--grey-400); text-transform: uppercase;
    }

    .piece-no { color: var(--red); font-size: 0.8rem; letter-spacing: 0.1em; }
    .page h2 { font-size: clamp(1.4rem, 3.5vw, 1.9rem); margin: 0.3rem 0 1.4rem; }
    .prose :global(p) { margin: 0 0 1.1rem; }

    .mag-controls {
      display: flex; align-items: center; justify-content: center; gap: 1.5rem;
      margin-top: 1.75rem;
    }
    .turn {
      font-family: var(--font-mono); font-size: 1.1rem;
      background: #fff; color: var(--ink);
      border: 1px solid var(--grey-200); border-radius: 0;
      width: 3rem; height: 3rem; cursor: pointer;
      transition: border-color .2s, color .2s, background .2s;
    }
    .turn:hover:not(:disabled) { border-color: var(--red); color: var(--red); }
    .turn:disabled { opacity: 0.3; cursor: default; }
    .folio { font-size: 0.85rem; letter-spacing: 0.1em; color: var(--grey-600); min-width: 5ch; text-align: center; }
    .folio .cur { color: var(--red); }

    @media (prefers-reduced-motion: reduce) {
      .page { transition: opacity .15s ease; transform: none !important; }
    }
  </style>

  <script>
    const mag = document.querySelector(".mag");
    if (mag) {
      const pages = Array.from(mag.querySelectorAll(".page"));
      const total = pages.length;
      const prevBtn = mag.querySelector(".prev");
      const nextBtn = mag.querySelector(".next");
      const cur = mag.querySelector(".folio .cur");
      let i = 0;
      let busy = false;

      function go(next) {
        if (busy || next === i || next < 0 || next >= total) return;
        busy = true;
        const forward = next > i;
        const leaving = pages[i];
        const entering = pages[next];

        leaving.classList.add(forward ? "turn-out-left" : "turn-out-right");
        leaving.classList.remove("is-active");

        entering.classList.add("is-active");
        entering.classList.remove("turn-out-left", "turn-out-right");

        i = next;
        cur.textContent = String(i + 1);
        prevBtn.disabled = i === 0;
        nextBtn.disabled = i === total - 1;

        window.setTimeout(() => {
          leaving.classList.remove("turn-out-left", "turn-out-right");
          busy = false;
        }, 460);
      }

      nextBtn.addEventListener("click", () => go(i + 1));
      prevBtn.addEventListener("click", () => go(i - 1));
      pages.forEach((p) =>
        p.querySelector(".page-inner").addEventListener("click", (e) => {
          if (e.target.closest("a")) return; // let links work
          const rect = p.getBoundingClientRect();
          const onLeft = e.clientX - rect.left < rect.width * 0.25;
          go(onLeft ? i - 1 : i + 1);
        })
      );
      document.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight") go(i + 1);
        if (e.key === "ArrowLeft") go(i - 1);
      });
    }
  </script>
</Base>
